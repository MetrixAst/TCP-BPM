# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
TRUSTED_ORIGINS=http://localhost,http://127.0.0.1

# PostgreSQL
POSTGRES_ENGINE=django.db.backends.postgresql
POSTGRES_DB=trc_bpm
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Celery
CELERY_BROKER_URL=redis://redis:6379/0

# Timezone
TZ=Asia/Almaty

# 1C Integration (old endpoints for OnecClient)
ONEC_URL=http://your-1c-server/api/
ALTERNATE_ONEC_URL=http://your-1c-alt-server/api/

# 1C Integration (new full client)
ONE_C_BASE_URL=https://your-1c-server/hs/api/v1
ONE_C_BASIC_AUTH_USER=Admin
ONE_C_BASIC_AUTH_PASSWORD=your-password
ONE_C_API_USER=admin
ONE_C_API_PASSWORD=your-password
